rules_version = '2';

// NOTE: This app currently has no Firebase Authentication, so these rules
// allow unauthenticated access to the `rides` collection. This is fine for
// development but is INSECURE for production — anyone with your project
// config can read/write rides. Before shipping, add Firebase Auth (or
// App Check) and restrict writes to authenticated/verified clients.
service cloud.firestore {
  match /databases/{database}/documents {
    match /rides/{rideId} {
      allow read, write: if true;
    }
    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
