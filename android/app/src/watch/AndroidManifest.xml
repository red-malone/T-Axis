<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ============================================================
         Wear OS hardware feature declarations.
         android.hardware.type.watch tells the Play Store this APK
         is for watches. "required=true" prevents it from being
         installed on phones.
         ============================================================ -->
    <uses-feature android:name="android.hardware.type.watch" />

    <!-- ============================================================
         Sensor features used by the telemetry system.
         required=false means the app still installs if the sensor
         is absent, but you should guard usage in code.
         ============================================================ -->
    <uses-feature
        android:name="android.hardware.sensor.accelerometer"
        android:required="true" />
    <uses-feature
        android:name="android.hardware.sensor.gyroscope"
        android:required="true" />
    <uses-feature
        android:name="android.hardware.location.gps"
        android:required="false" />

    <application
        android:label="T-Axis Watch"
        tools:replace="android:label">

        <!-- ========================================================
             Mark this as a Wear OS standalone app — it does NOT
             require a paired phone app to function.
             ======================================================== -->
        <meta-data
            android:name="com.google.android.wearable.standalone"
            android:value="true" />

        <!-- ========================================================
             Ambient mode support — keeps the app visible when the
             watch screen dims. Important for ride tracking where
             the rider needs to glance at data without waking the
             watch. The Flutter wear_plus plugin uses this.
             ======================================================== -->
        <uses-library
            android:name="com.google.android.wearable"
            android:required="false" />
    </application>
</manifest>